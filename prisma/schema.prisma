generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  status    String
  isPublic  Boolean  @default(false)
  role      String   @default("member")
  createdAt DateTime @default(now())
}
